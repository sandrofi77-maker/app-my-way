# Supabase — credenciais públicas do cliente
# Pegue em: https://supabase.com/dashboard/project/<SEU_PROJETO>/settings/api
EXPO_PUBLIC_SUPABASE_URL=https://<seu-projeto>.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=<sua-anon-key>

# NUNCA colocar SUPABASE_SERVICE_ROLE_KEY neste arquivo.
# Service role só pode ser usada no backend (Edge Functions / server).
